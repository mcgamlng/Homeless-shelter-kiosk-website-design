+    replaceWithDefaultActivities(database);
+    setActivityPresetVersion(database);
+    return;
+  }
+
+  const storedPresetVersion = database
+    .prepare("SELECT value FROM settings WHERE key = 'activity_preset_version'")
+    .get()?.value;
+  if (!storedPresetVersion && usesLegacyDefaultActivities(database)) {
+    replaceWithDefaultActivities(database);
+    setActivityPresetVersion(database);
+  }
+}
+
+export function replaceWithDefaultActivities(database) {
+  const existing = database.prepare("SELECT id FROM activities ORDER BY sort_order, id").all();
+  const updateActivity = database.prepare(
+    `UPDATE activities
+     SET name = ?, name_es = ?, name_hmn = ?, name_so = ?,
+         duration_minutes = ?, time_limit_enabled = ?,
+         availability_window_enabled = 0,
+         availability_start = '08:00', availability_end = '16:00',
+         monthly_window_enabled = 0, monthly_start_day = 1, monthly_end_day = 31,
+         yearly_window_enabled = 0, yearly_start = '01-01', yearly_end = '12-31',
+         daily_limit_enabled = 0, daily_limit = NULL,
+         alarm_enabled = 0, alarm_minutes_before = 5,
+         icon = ?, active = 1, sort_order = ?, updated_at = CURRENT_TIMESTAMP
+     WHERE id = ?`
+  );
+  const insertActivity = database.prepare(
+    `INSERT INTO activities
+     (name, name_es, name_hmn, name_so,
+      duration_minutes, time_limit_enabled, availability_window_enabled,
+      availability_start, availability_end,
+      monthly_window_enabled, monthly_start_day, monthly_end_day,
+      yearly_window_enabled, yearly_start, yearly_end,
+      daily_limit_enabled, daily_limit,
+      alarm_enabled, alarm_minutes_before, icon, active, sort_order)
+     VALUES (?, ?, ?, ?, ?, ?, 0, '08:00', '16:00',
+             0, 1, 31, 0, '01-01', '12-31',
+             0, NULL, 0, 5, ?, 1, ?)`
+  );
+  const deactivateExtra = database.prepare(
+    `UPDATE activities
+     SET active = 0, sort_order = ?, updated_at = CURRENT_TIMESTAMP
+     WHERE id = ?`
+  );
+  const transaction = database.transaction(() => {
+    DEFAULT_ACTIVITIES.forEach((activity, index) => {
+      const translations = buildActivityTranslations(activity.name);
+      const params = [
+        activity.name,
+        translations.name_es,
+        translations.name_hmn,
+        translations.name_so,
+        activity.minutes,
+        activity.timed ? 1 : 0,
+        activity.icon,
+        index + 1
+      ];
+      const existingRow = existing[index];
+      if (existingRow) {
+        updateActivity.run(...params, existingRow.id);
+      } else {
+        insertActivity.run(...params);
+      }
     });
-    insertActivities();
-  }
+    existing.slice(DEFAULT_ACTIVITIES.length).forEach((row, index) => {
+      deactivateExtra.run(DEFAULT_ACTIVITIES.length + index + 1, row.id);
+    });
+    setActivityPresetVersion(database);
+  });
+  transaction();
+}
+
+function usesLegacyDefaultActivities(database) {
+  const names = database
+    .prepare("SELECT name FROM activities ORDER BY sort_order, id")
+    .all()
+    .map((row) => normalizePresetName(row.name));
+  if (names.length !== LEGACY_DEFAULT_ACTIVITY_NAMES.length) return false;
+  return LEGACY_DEFAULT_ACTIVITY_NAMES.every(
+    (name, index) => names[index] === normalizePresetName(name)
+  );
+}
+
+function setActivityPresetVersion(database) {
+  database
+    .prepare(
+      `INSERT INTO settings (key, value, updated_at)
+       VALUES ('activity_preset_version', ?, CURRENT_TIMESTAMP)
+       ON CONFLICT(key) DO UPDATE SET value = excluded.value, updated_at = CURRENT_TIMESTAMP`
+    )
+    .run(DEFAULT_ACTIVITY_PRESET_VERSION);
+}
+
+function normalizePresetName(value) {
+  return String(value || "")
+    .trim()
+    .toLowerCase()
+    .replace(/\s+/g, " ");
 }
 
