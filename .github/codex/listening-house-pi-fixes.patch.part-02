+function cleanDateKey(value) {
+  const parsed = parseRequestedReportDate(value);
+  return parsed ? formatDateKey(parsed) : "";
+}
+
+function getDayBoundsFromDateKey(dateKey) {
+  const start = parseRequestedReportDate(dateKey) || new Date();
+  start.setHours(0, 0, 0, 0);
+  const end = new Date(start);
+  end.setDate(end.getDate() + 1);
+  return { start, end };
+}
+
+function normalizeDailyExportArchive(row) {
+  if (!row) return null;
+  return {
+    id: row.id,
+    report_date: row.report_date,
+    filename: row.filename,
+    file_path: row.file_path,
+    created_at: row.created_at,
+    emailed_at: row.emailed_at || "",
+    email_recipient: row.email_recipient || "",
+    email_status: row.email_status || "not_configured",
+    error_message: row.error_message || ""
+  };
+}
