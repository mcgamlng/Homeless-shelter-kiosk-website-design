@@ -0,0 +1,226 @@
+import fs from "node:fs";
+import os from "node:os";
+import path from "node:path";
+import { fileURLToPath } from "node:url";
+import nodemailer from "nodemailer";
+import {
+  createAnalyticsWorkbook,
+  getDailyExportArchive,
+  getDailyExportArchiveByDate,
+  getDailyExportSettings,
+  listDailyExportArchives,
+  purgeArchivedRawData,
+  setDailyExportLastRunDate,
+  updateDailyExportEmailStatus,
+  upsertDailyExportArchive
+} from "./repository.js";
+
+const __dirname = path.dirname(fileURLToPath(import.meta.url));
+const projectRoot = path.resolve(__dirname, "..");
+const defaultExportDir = path.join(projectRoot, "data", "exports");
+const schedulerState = {
+  timer: null,
+  running: false
+};
+
+export function getDailyExports() {
+  return listDailyExportArchives();
+}
+
+export function getDailyExportFile(id) {
+  const archive = getDailyExportArchive(id);
+  if (!archive) {
+    const error = new Error("Daily export was not found.");
+    error.status = 404;
+    throw error;
+  }
+  if (!archive.file_path || !fs.existsSync(archive.file_path)) {
+    const error = new Error("The saved spreadsheet file is missing on this Raspberry Pi.");
+    error.status = 404;
+    throw error;
+  }
+  return archive;
+}
+
+export async function runDailyExport({
+  reportDate = previousDateKey(),
+  force = false,
+  transporterFactory = createGmailTransport
+} = {}) {
+  const settings = getDailyExportSettings({ includeSecret: true });
+  const existing = getDailyExportArchiveByDate(reportDate);
+  if (existing && !force) {
+    return existing;
+  }
+
+  const workbook = createAnalyticsWorkbook({ period: "day", date: reportDate });
+  const exportDir = process.env.DAILY_EXPORT_DIR || defaultExportDir;
+  fs.mkdirSync(exportDir, { recursive: true });
+  const filename = safeSpreadsheetFilename(workbook.filename, reportDate);
+  const filePath = path.join(exportDir, filename);
+  fs.writeFileSync(filePath, workbook.buffer);
+
+  let archive = upsertDailyExportArchive({
+    reportDate,
+    filename,
+    filePath,
+    emailStatus: emailCanSend(settings) ? "pending" : "not_configured",
+    emailRecipient: settings.recipient_email
+  });
+
+  if (!settings.enabled) {
+    archive = updateDailyExportEmailStatus(archive.id, {
+      emailStatus: "disabled",
+      emailRecipient: settings.recipient_email
+    });
+  } else if (emailCanSend(settings)) {
+    archive = await sendDailyExportEmail({
+      archive,
+      workbook,
+      settings,
+      transporterFactory
+    });
+  }
+
+  purgeArchivedRawData({ retentionDays: settings.retention_days });
+  return archive;
+}
+
+export async function testDailyExportEmail({ transporterFactory = createGmailTransport } = {}) {
+  const settings = getDailyExportSettings({ includeSecret: true });
+  if (!emailCanSend(settings)) {
+    const error = new Error(
+      "Enter Gmail, app password, and recipient before sending a test email."
+    );
+    error.status = 400;
+    throw error;
+  }
+  const transporter = transporterFactory(settings);
+  await transporter.sendMail({
+    from: settings.sender_email,
+    to: settings.recipient_email,
+    subject: "Listening House daily export test",
+    text: "This is a test from the Listening House kiosk. If you can read this, the Pi can email daily spreadsheets."
+  });
+  return { ok: true, recipient_email: settings.recipient_email };
+}
+
+export function startDailyExportScheduler({ intervalMs = 60 * 1000 } = {}) {
+  if (schedulerState.timer) return schedulerState.timer;
+  const tick = () => {
+    dailyExportTick().catch((error) => {
+      console.error("Daily export failed:", error);
+    });
+  };
+  schedulerState.timer = setInterval(tick, intervalMs);
+  schedulerState.timer.unref?.();
+  setTimeout(tick, 5000).unref?.();
+  return schedulerState.timer;
+}
+
+export function stopDailyExportScheduler() {
+  if (!schedulerState.timer) return;
+  clearInterval(schedulerState.timer);
+  schedulerState.timer = null;
+}
+
+export async function dailyExportTick({ now = new Date() } = {}) {
+  if (schedulerState.running) return null;
+  const settings = getDailyExportSettings({ includeSecret: true });
+  if (!settings.enabled) return null;
+  const today = formatDateKey(now);
+  if (settings.last_run_date === today) return null;
+  if (!isAtOrAfterExportTime(now, settings.export_time)) return null;
+
+  schedulerState.running = true;
+  try {
+    const archive = await runDailyExport({ reportDate: previousDateKey(now) });
+    setDailyExportLastRunDate(today);
+    return archive;
+  } finally {
+    schedulerState.running = false;
+  }
+}
+
+async function sendDailyExportEmail({ archive, workbook, settings, transporterFactory }) {
+  try {
+    const transporter = transporterFactory(settings);
+    await transporter.sendMail({
+      from: settings.sender_email,
+      to: settings.recipient_email,
+      subject: `Listening House daily spreadsheet - ${archive.report_date}`,
+      text: `Attached is the Listening House daily spreadsheet for ${archive.report_date}.`,
+      attachments: [
+        {
+          filename: archive.filename,
+          content: workbook.buffer,
+          contentType: "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
+        }
+      ]
+    });
+    return updateDailyExportEmailStatus(archive.id, {
+      emailStatus: "sent",
+      emailRecipient: settings.recipient_email
+    });
+  } catch (error) {
+    return updateDailyExportEmailStatus(archive.id, {
+      emailStatus: "failed",
+      emailRecipient: settings.recipient_email,
+      errorMessage: error.message || "Email failed."
+    });
+  }
+}
+
+function createGmailTransport(settings) {
+  return nodemailer.createTransport({
+    service: "gmail",
+    auth: {
+      user: settings.sender_email,
+      pass: settings.app_password
+    }
+  });
+}
+
