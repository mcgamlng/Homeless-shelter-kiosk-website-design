   });
   transaction();
   return getSettings();
+}
+
+export function getDailyExportSettings({ includeSecret = false } = {}) {
+  const appPassword = getSettingValue("daily_export_app_password");
+  return {
+    enabled: getSettingValue("daily_export_enabled") !== "0",
+    export_time: normalizeClockTime(getSettingValue("daily_export_time"), "03:00"),
+    retention_days: Math.max(7, Number(getSettingValue("daily_export_retention_days") || 7)),
+    sender_email: getSettingValue("daily_export_sender_email"),
+    recipient_email: getSettingValue("daily_export_recipient_email"),
+    has_app_password: Boolean(appPassword),
+    last_run_date: getSettingValue("daily_export_last_run_date"),
+    ...(includeSecret ? { app_password: appPassword } : {})
+  };
+}
+
+export function updateDailyExportSettings(settings = {}) {
+  const next = {
+    daily_export_enabled: settings.enabled,
+    daily_export_time: settings.export_time,
+    daily_export_retention_days: settings.retention_days,
+    daily_export_sender_email: settings.sender_email,
+    daily_export_recipient_email: settings.recipient_email
+  };
+  if (Object.hasOwn(settings, "app_password")) {
+    next.daily_export_app_password = settings.app_password;
+  }
+  if (settings.clear_app_password) {
+    next.daily_export_app_password = "";
+  }
+  updateSettings(next);
+  return getDailyExportSettings();
+}
+
+export function setDailyExportLastRunDate(dateKey) {
+  updateSetting("daily_export_last_run_date", dateKey);
+}
+
+export function listDailyExportArchives({ limit = 21 } = {}) {
+  return rows(
+    `SELECT id, report_date, filename, file_path, created_at, emailed_at,
+            email_recipient, email_status, error_message
+     FROM daily_export_archives
+     ORDER BY report_date DESC
+     LIMIT ?`,
+    [Math.max(1, Math.min(100, Number(limit) || 21))]
+  ).map(normalizeDailyExportArchive);
+}
+
+export function getDailyExportArchive(id) {
+  return normalizeDailyExportArchive(
+    one(
+      `SELECT id, report_date, filename, file_path, created_at, emailed_at,
+              email_recipient, email_status, error_message
+       FROM daily_export_archives
+       WHERE id = ?`,
+      [id]
+    )
+  );
+}
+
+export function getDailyExportArchiveByDate(reportDate) {
+  return normalizeDailyExportArchive(
+    one(
+      `SELECT id, report_date, filename, file_path, created_at, emailed_at,
+              email_recipient, email_status, error_message
+       FROM daily_export_archives
+       WHERE report_date = ?`,
+      [reportDate]
+    )
+  );
+}
+
+export function upsertDailyExportArchive(archive) {
+  const cleanArchive = {
+    reportDate: cleanDateKey(archive.reportDate),
+    filename: cleanText(archive.filename, 220),
+    filePath: String(archive.filePath || "").trim(),
+    emailStatus: cleanText(archive.emailStatus || "not_configured", 40),
+    emailRecipient: cleanText(archive.emailRecipient || "", 220),
+    errorMessage: cleanText(archive.errorMessage || "", 500)
+  };
+  if (!cleanArchive.reportDate || !cleanArchive.filename || !cleanArchive.filePath) {
+    const error = new Error("Daily export archive is missing required metadata.");
+    error.status = 400;
+    throw error;
+  }
+  db.prepare(
+    `INSERT INTO daily_export_archives
+       (report_date, filename, file_path, email_status, email_recipient, error_message)
+     VALUES (?, ?, ?, ?, ?, ?)
+     ON CONFLICT(report_date) DO UPDATE SET
+       filename = excluded.filename,
+       file_path = excluded.file_path,
+       created_at = CURRENT_TIMESTAMP,
+       email_status = excluded.email_status,
+       email_recipient = excluded.email_recipient,
+       error_message = excluded.error_message`
+  ).run(
+    cleanArchive.reportDate,
+    cleanArchive.filename,
+    cleanArchive.filePath,
+    cleanArchive.emailStatus,
+    cleanArchive.emailRecipient,
+    cleanArchive.errorMessage
+  );
+  return getDailyExportArchiveByDate(cleanArchive.reportDate);
+}
+
+export function updateDailyExportEmailStatus(id, status) {
+  db.prepare(
+    `UPDATE daily_export_archives
+     SET email_status = ?,
+         emailed_at = CASE WHEN ? = 'sent' THEN CURRENT_TIMESTAMP ELSE emailed_at END,
+         email_recipient = ?,
+         error_message = ?,
+         created_at = created_at
+     WHERE id = ?`
+  ).run(
+    cleanText(status.emailStatus || "not_configured", 40),
+    cleanText(status.emailStatus || "not_configured", 40),
+    cleanText(status.emailRecipient || "", 220),
+    cleanText(status.errorMessage || "", 500),
+    id
+  );
+  return getDailyExportArchive(id);
+}
+
+export function purgeArchivedRawData({ retentionDays = 7, now = new Date() } = {}) {
+  const cutoff = new Date(now);
+  cutoff.setHours(0, 0, 0, 0);
+  cutoff.setDate(cutoff.getDate() - Math.max(7, Number(retentionDays) || 7));
+  const cutoffKey = formatDateKey(cutoff);
+  const archives = rows(
+    `SELECT report_date
+     FROM daily_export_archives
+     WHERE report_date < ?
+       AND file_path <> ''`,
+    [cutoffKey]
+  );
+  let deletedCheckIns = 0;
+  const transaction = db.transaction(() => {
+    archives.forEach((archive) => {
+      const bounds = getDayBoundsFromDateKey(archive.report_date);
+      const info = db
+        .prepare(
+          `DELETE FROM check_ins
+           WHERE checked_in_at >= ?
+             AND checked_in_at < ?`
+        )
+        .run(formatSqliteUtcTimestamp(bounds.start), formatSqliteUtcTimestamp(bounds.end));
+      deletedCheckIns += info.changes || 0;
+    });
+  });
+  transaction();
+  return { deletedCheckIns, cutoffDate: cutoffKey };
+}
+
+export function restoreListeningHouseDefaultActivities() {
+  replaceWithDefaultActivities(db);
+  return getDashboardData();
 }
 
